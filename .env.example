# ─── Google OAuth ─────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── NextAuth ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# If your GCP Redirect URI is http://localhost:8080/api/auth/callback/google
NEXTAUTH_URL=http://localhost:8080
NEXTAUTH_SECRET=your-nextauth-secret
AUTH_TRUST_HOST=true

# ─── Admin Access ─────────────────────────────────────────
# Only this email can access the admin dashboard
ADMIN_EMAIL=your-email@gmail.com

# ─── Database ─────────────────────────────────────────────
DATABASE_URL="mysql://photos_user:photos_pass@127.0.0.1:3306/photos_showcase"

# ─── Cron (Optional, recommended for production) ──────────
CRON_SECRET=your-cron-secret

# ─── Site Config (Optional) ──────────────────────────────
SITE_NAME="My Photo Showcase"
